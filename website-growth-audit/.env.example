# Google PageSpeed Insights API key (free) — get it at https://console.cloud.google.com
GOOGLE_PAGESPEED_API_KEY=

# NVIDIA API key (free tier) — get it at https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# Stripe Payment Link — create in Stripe Dashboard → Payment Links, paste the URL here
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# Optional: get emailed every time someone runs a scan (via Resend, free tier)
RESEND_API_KEY=
NOTIFY_EMAIL=you@yourdomain.com
NOTIFY_FROM=leads@yourdomain.com
